# --- Pripojenie na Strapi CMS ------------------------------------------
# Adresa bežiaceho Strapi backendu (repozitár katedrala-strapi).
# Lokálny vývoj: http://localhost:1337
# Produkcia: sem daj skutočnú verejnú adresu, na ktorej beží CMS
# (napr. https://cms.katedralabratislava.sk).
# STRAPI_URL sa používa len na serveri (Server Components, API routy).
# NEXT_PUBLIC_STRAPI_URL je to isté, ale dostupné aj v prehliadači —
# používa sa na skladanie URL adries fotiek (getStrapiMediaUrl).
# Musia byť vyplnené OBE a mať rovnakú hodnotu.
STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# --- Adresa tohto webu ---------------------------------------------------
# Skutočná verejná adresa webu (bez lomítka na konci). Používa sa v
# sitemap.xml, robots.txt a v SEO meta tagoch (og:image a pod.).
# Lokálny vývoj: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Strapi API tokeny -----------------------------------------------------
# Vytvor v Strapi admine: Settings → API Tokens → Create new API Token.
#
# 1) STRAPI_API_TOKEN — typ "Read-only". Používa sa na všetky GET požiadavky.
#    Nie je striktne povinný (Strapi má nastavené aj verejné čítanie), ale
#    odporúča sa ho vyplniť pre istotu, keby sa verejné práva niekedy vypli.
STRAPI_API_TOKEN=
#
# 2) STRAPI_FORMS_TOKEN — typ "Custom", právo len "create" na obsahové typy
#    Reservation/Excursion/ContactMessage. Potrebný iba ak/keď pribudnú
#    formuláre na webe, ktoré zapisujú do Strapi. Zatiaľ sa nepoužíva.
STRAPI_FORMS_TOKEN=

# --- Webhook pre okamžitú aktualizáciu obsahu (ISR revalidation) ---------
# Ľubovoľný dlhý náhodný reťazec (napr. vygeneruj cez `openssl rand -hex 32`).
# Rovnaká hodnota sa potom nastaví v Strapi: Settings → Webhooks → nový
# webhook → header "x-revalidate-secret". Bez tohto webhooku sa zmeny
# v Strapi prejavia na webe až po uplynutí revalidačného intervalu (pozri
# web/CLAUDE.md), takže to nie je nutné pre základné fungovanie webu.
REVALIDATE_SECRET=
